# Kinetic v0 — environment template
# Copy to .env.local and fill in real values before running real-provider regression.
# Never commit .env.local.

# LLM provider selection: a concrete provider (mock | gemini | claude | ollama |
# openai) forces that one for every capture; "auto" engages privacy-aware routing
# (see the routing block below). Default mock = zero-setup demo.
KINETIC_PROVIDER=mock

# Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Local Ollama provider (no key; runs on your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Privacy-aware LLM routing (Phase B). Active only when KINETIC_PROVIDER=auto.
# Sensitive captures (non-business / unknown hint, or a pinned source) route to
# the local provider; business captures route to the cloud provider. A sensitive
# capture overridden to a cloud provider needs acknowledge_cloud in the request.
KINETIC_LOCAL_PROVIDER=ollama
KINETIC_CLOUD_PROVIDER=claude
# Comma-separated source names always routed local regardless of hint (e.g. a
# personal mailbox): gmail_sent,outlook_sent
KINETIC_LOCAL_SOURCES=

# Supabase persistence (M7). When SUPABASE_URL is set, the server persists
# captures / proof cards / oauth tokens via PostgREST instead of the in-memory
# store. Server-side code uses the service role key; the client never sees it.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AES-256-GCM key for encrypting OAuth refresh/access tokens at rest (M7).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KINETIC_TOKEN_ENCRYPTION_KEY=

# Public base URL the OAuth redirect URIs are built from (M7).
# Must match the redirect URIs registered with Google / Microsoft.
KINETIC_BASE_URL=http://localhost:5173

# Google OAuth (M7) — Cloud Console > APIs & Services > Credentials > OAuth client (Web)
# Redirect URI to register: ${KINETIC_BASE_URL}/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft OAuth (M7) — Azure Portal > App registrations
# Redirect URI to register: ${KINETIC_BASE_URL}/oauth/microsoft/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common

# Google Calendar harvester (optional — UI accepts pasted tokens too)
# Get a short-lived access token from https://developers.google.com/oauthplayground
# Required scope: https://www.googleapis.com/auth/calendar.readonly
# Token lasts ~1h; paste in the UI instead for ad-hoc use.
GOOGLE_ACCESS_TOKEN=

# Microsoft Graph harvester debug token (optional — same role as GOOGLE_ACCESS_TOKEN)
MS_ACCESS_TOKEN=
